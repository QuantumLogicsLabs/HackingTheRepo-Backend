# MongoDB
MONGO_URI=mongodb://localhost:27017/repomind

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# RepoMind Bot Config (SENDROOM - the bot that creates PRs)
REPOMIND_GITHUB_TOKEN=ghp_your_bot_github_token_here
REPOMIND_GITHUB_USERNAME=your-bot-github-username

# RepoMind FastAPI backend
REPOMIND_API_URL=http://localhost:8000

# OpenAI (passed to RepoMind)
OPENAI_API_KEY=sk-your-openai-key-here

PORT=5000
