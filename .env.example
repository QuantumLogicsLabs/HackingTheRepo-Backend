# backend/.env.example
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/mern-ai-agent

# Comma-separated list of GitHub Repos to track & update (Owner/Repo)
# e.g., facebook/react,vercel/next.js
GITHUB_REPOS=your_username/your_repo

GITHUB_TOKEN=your_github_personal_access_token_here

# AI Service Keys (The system will try them in this fallback order)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
PUTER_API_KEY=your_puter_api_key_here

# Phase 1: Context & Memory (Optional)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name_here
